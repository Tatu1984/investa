# --------------------------------------------------------------
# Investa · environment template
# Copy to .env.local and fill in. Never commit real secrets.
# --------------------------------------------------------------

NODE_ENV=development
APP_URL=http://localhost:3000

# ---- Database ----
# Paste your NeonDB Postgres URL here. Format:
# postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ---- Auth ----
# Generate with:  openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-please-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-too-at-least-32-chars-long-value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ---- Cookies ----
# Leave empty in dev; set to your domain in prod (e.g. .investa.app).
COOKIE_DOMAIN=
# Set to true in production (HTTPS). false for localhost.
COOKIE_SECURE=false

# ---- Analytics service (FastAPI, added later) ----
ANALYTICS_INTERNAL_URL=
ANALYTICS_INTERNAL_KEY=

# ---- LLM (optional) ----
ANTHROPIC_API_KEY=
LLM_DAILY_BUDGET_USD=5

# ---- Cron (Vercel Cron) ----
# Used by Vercel Cron to authenticate scheduled ingestion hits.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ---- Email (Resend) — Phase E ----
RESEND_API_KEY=
RESEND_FROM=no-reply@investa.local

# ---- Logging ----
LOG_LEVEL=info
